db_host=localhost
db_port=3306
db_user=root
db_password=sua_senha_do_mysql
db_name=praiastur_inventario

admin_name=Usuário ADM
admin_email=admin@praiastur.com.br
admin_password=123456

jwt_secret=sua_chave_secreta_aqui
jwt_expires_in=1d

# Quando pg_con estiver preenchido, o sistema usa PostgreSQL/Neon.
# Quando pg_con estiver vazio, o sistema usa MySQL local.
pg_con=postgresql://usuario:senha@host/neondb?sslmode=require

port=3000
client_url=http://localhost:5173